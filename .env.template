# Database
# App default datasource (for non-docker run, e.g. dev with RDS)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint:5432/your_db
DB_NAME=your_database_name
DB_PW=your_database_password
# Optional for local IDE run (recommended)
# SPRING_DATASOURCE_USERNAME=your_local_pg_user
# SPRING_DATASOURCE_PASSWORD=your_local_pg_password

# Docker local override (optional)
# If not set, docker-compose.yml uses postgres container by default.
# SPRING_DATASOURCE_URL_DOCKER=jdbc:postgresql://postgres:5432/seatrace

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Docker local override (optional)
# REDIS_HOST_DOCKER=redis
# REDIS_PORT_DOCKER=6379

# JWT
JWT_SECRET=your_32byte_base64_secret_key
